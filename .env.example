# D-Time Application Environment Configuration
# Copy this file to .env and customize the values
# NEVER commit actual credentials to version control

# ===== DATABASE CONFIGURATION =====
# Database name - change this to use a different database
DATABASE_NAME=dtime

# Database username - change this to use a different user
DATABASE_USERNAME=dtime

# Database password - CHANGE THIS FOR PRODUCTION!
DATABASE_PASSWORD=dtime_dev_password

# Host port for dtime-db in Docker (default 5433 to avoid clashing with Postgres on 5432)
DATABASE_HOST_PORT=5433

# ===== BACKEND CONFIGURATION =====
# Spring profile to use (dev, docker, prod)
SPRING_PROFILES_ACTIVE=docker

# Enable/disable CSRF protection (true for production, false for development)
SECURITY_CSRF_ENABLED=false

# ===== OAUTH CONFIGURATION (AUTHENTIK OIDC) =====
OAUTH_AUTHENTIK_ENABLED=true
OAUTH_AUTHENTIK_CLIENT_ID=your-authentik-client-id
OAUTH_AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret
OAUTH_AUTHENTIK_AUTHORIZATION_URI=http://localhost:9000/application/o/authorize/
OAUTH_AUTHENTIK_END_SESSION_URI=http://localhost:9000/application/o/dtime/end-session/
OAUTH_AUTHENTIK_REQUIRE_APP_ROLE=true
OAUTH_AUTHENTIK_TOKEN_URI=http://localhost:9000/application/o/token/
OAUTH_AUTHENTIK_USER_INFO_URI=http://localhost:9000/application/o/userinfo/
# JWKS must match the Authentik OAuth2 provider that signs both browser and MCP tokens (slug in path, e.g. .../o/dtime/jwks/).
OAUTH_AUTHENTIK_JWK_SET_URI=http://localhost:9000/application/o/dtime/jwks/

# Bearer JWT access for machine clients (e.g. dtime-mcp) in addition to browser sessions.
# Set enabled=true once you configure a confidential Authentik client using client_credentials
# and list its client identifier in AUTHORIZED_CLIENT_IDS (must match access token claims client_id, azp, or sub).
# Required for dtime-mcp (backend dev profile defaults below when unset).
OAUTH_AUTHENTIK_MACHINE_JWT_ENABLED=true
# JWKS for MCP tokens (Authentik provider slug dtmcp). Browser OIDC keeps OAUTH_AUTHENTIK_JWK_SET_URI .../dtime/jwks/.
OAUTH_AUTHENTIK_MACHINE_JWT_JWK_SET_URI=http://localhost:9000/application/o/dtmcp/jwks/
# azp / client_id from MCP access token (mcp/scripts/print-access-token-claims.sh). Dev YAML default if empty.
OAUTH_AUTHENTIK_MACHINE_JWT_AUTHORIZED_CLIENT_IDS=ncFDhaBcHjh5jzwUdrmxzj08oDDuMSivl2Ai5Mvi

# OAuth callback URI (Authentik redirects the browser here after login). Default in application-dev.yml:
#   https://localhost:8443/login/oauth2/code/authentik
# Switch-user post-logout redirect (add in Authentik Redirect URIs — no query string):
#   https://localhost:8443/api/auth/oidc/switch-user/resume
# Optional SPA fallback (webpack proxies /api to backend):
#   https://localhost:3000/api/auth/oidc/switch-user/resume
# OAUTH_AUTHENTIK_REDIRECT_URI=https://localhost:8443/login/oauth2/code/authentik
# OAUTH_AUTHENTIK_BACKEND_PUBLIC_BASE_URL=https://localhost:8443
# OAUTH_AUTHENTIK_SWITCH_USER_IDP_LOGOUT=false

# ===== MAIL CONFIGURATION =====
# Enable/disable email functionality
MAIL_ENABLED=false

# Email credentials (only needed if MAIL_ENABLED=true)
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# ===== FRONTEND CONFIGURATION =====
# Backend URL as seen from the frontend browser
# 
# DEPLOYMENT SCENARIOS:
# 1. Local Docker (./deploy.sh --env development):
#    Frontend runs in container, accessed via browser at localhost:3000
#    Use: https://localhost:8443 (browser -> host -> container)
#
# 2. Production deployment on server:
#    Frontend runs in container, accessed via domain name
#    Use: https://your-domain.com (browser -> domain -> container)
#
# 3. Local development (npm start + IntelliJ):
#    Frontend runs locally, backend in container or local
#    Use: https://localhost:8443
#
# Leave empty to use automatic defaults based on deployment type
FRONTEND_BACKEND_URL=

# ===== MCP SERVER (spring-ai module; docker-compose profiles: mcp or full-stack) =====
# Port on host and inside the MCP container (backend uses 8443, frontend dev 3000).
MCP_PORT=8081
# Spring profiles for the MCP jar in Docker; see mcp/src/main/resources/application.yml
MCP_SPRING_PROFILES_ACTIVE=docker,prod
# Leave empty for compose defaults: backend service URL inside the Docker network
MCP_BACKEND_URL=
# Authentik confidential client used only for MCP (recommended), or separate M2M client.
# Must match Authentik dtmcp confidential app; same value as OAUTH_AUTHENTIK_MACHINE_JWT_AUTHORIZED_CLIENT_IDS (token azp).
MCP_OAUTH_CLIENT_ID=ncFDhaBcHjh5jzwUdrmxzj08oDDuMSivl2Ai5Mvi
MCP_OAUTH_CLIENT_SECRET=mcp-example-client-secret
# Override if Authentik is not reachable at host.docker.internal from the MCP container (Linux users may need extra_hosts).
MCP_OAUTH_TOKEN_URI=http://host.docker.internal:9000/application/o/token/
# Optional scopes for client_credentials grant
MCP_OAUTH_SCOPE=
MCP_VALIDATE_ON_STARTUP=true
MCP_JAVA_OPTS=-Xmx512m -Xms256m
# Trust backend HTTPS without importing dev keystore (self-signed). Default true for Spring profile dev/docker in application.yml; set false when backend uses a public CA.
MCP_BACKEND_TRUST_INSECURE_SSL=

# For local MCP (mvn spring-boot:run outside Docker): set MCP_BACKEND_URL=https://localhost:8443
# and MCP_OAUTH_TOKEN_URI=http://localhost:9000/application/o/token/ (often already default via profile dev).
# MCP_PORT does not affect mvn locally; use SERVER_PORT instead if you change the MCP listen port.

# ===== OLLAMA + MCP BRIDGE (profiles: ollama with mcp / full-stack) =====
# Ollama API on host (container dtime-ollama). Do not expose to the public internet.
OLLAMA_PORT=11434
# ollama-mcp-bridge (container dtime-ollama-bridge; maps host 8082 -> container 8000)
OLLAMA_BRIDGE_PORT=8082
# Default model for admin Chat UI (must be pulled: docker exec dtime-ollama ollama pull llama3.2)
# If you see out-of-memory errors, use llama3.2:1b or increase Docker RAM — see ollama/README.md#memory-and-model-choice
OLLAMA_DEFAULT_MODEL=llama3.2
# Bridge MCP config mounted in compose (path on host)
OLLAMA_BRIDGE_CONFIG_PATH=./ollama/bridge-config.json
# Dev webpack proxy target when running npm start on the host (bridge on localhost:8082)
OLLAMA_BRIDGE_URL=http://localhost:8082
# Comma-separated origins for bridge CORS (dev frontend)
OLLAMA_BRIDGE_CORS_ORIGINS=http://localhost:3000,https://localhost:3000
# Optional system prompt prepended to /api/chat by the bridge
# OLLAMA_BRIDGE_SYSTEM_PROMPT=... (default in ollama/docker-compose.bridge.yml guides monthly org reports via getMonthlyUserReportSummary)
# Ollama HTTP timeout for bridge proxy (ms); streaming chat ignores timeout
OLLAMA_PROXY_TIMEOUT=600000
# MCP config file inside ollama/ (bridge-config.json = dtime-mcp container; bridge-config.host-mcp.json = MCP on host :8081)
BRIDGE_MCP_CONFIG=bridge-config.json

# ===== SSL CONFIGURATION (for production) =====
SSL_KEYSTORE_PASSWORD=your_keystore_password